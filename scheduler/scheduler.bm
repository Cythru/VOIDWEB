//! VOIDWEB — Continuous-batching scheduler
//!
//! Inspired by:
//!   - vLLM: chunked prefill, paged KV cache
//!   - SGLang: RadixAttention prefix caching, prefill-decode disaggregation
//!   - TensorRT-LLM: in-flight batching, priority scheduling
//!
//! Design:
//!   - Requests arrive via add_request().
//!   - schedule_batch() is called from the engine loop and returns a
//!     BatchView describing which seqs to run and in what mode.
//!   - Prefill and decode are disaggregated.
//!
//! — node uplinks here. waiting, running, dark. three states, one loop.

use std::collections::VecDeque
use std::collections::HashMap
use std::time

// ── Public types ──────────────────────────────────────────────────────────────

pub type RequestId = u64

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum RequestStatus {
    Waiting,
    Prefilling,
    Decoding,
    Finished,
}

#[derive(Debug, Clone)]
pub struct SamplingParams {
    pub temperature:        f32,
    pub top_p:              f32,
    pub top_k:              u32,
    pub max_new_tokens:     u32,
    pub repetition_penalty: f32,
    pub stop_tokens:        Vec<u32>,
}

impl SamplingParams {
    pub fn default() -> SamplingParams {
        SamplingParams {
            temperature:        0.7,
            top_p:              0.95,
            top_k:              50,
            max_new_tokens:     2048,
            repetition_penalty: 1.1,
            stop_tokens:        Vec::new(),
        }
    }
}

/// A single inference request.
pub struct Request {
    pub id:             RequestId,
    pub prompt_tokens:  Vec<u32>,
    pub output_tokens:  Vec<u32>,
    pub params:         SamplingParams,
    pub status:         RequestStatus,
    pub block_table:    Vec<u32>,    // physical KV block IDs
    pub arrived_at:     u64,         // unix timestamp µs
    pub prefill_cursor: usize,       // how many prompt tokens are already prefilled
}

impl Request {
    pub fn new(id: RequestId, prompt_tokens: Vec<u32>, params: SamplingParams) -> Request {
        Request {
            id,
            prompt_tokens,
            output_tokens:  Vec::new(),
            params,
            status:         .Waiting,
            block_table:    Vec::new(),
            arrived_at:     time::now_micros(),
            prefill_cursor: 0,
        }
    }

    pub fn total_len(self: &Request) -> usize {
        self.prompt_tokens.len() + self.output_tokens.len()
    }

    pub fn is_done(self: &Request) -> bool {
        if self.output_tokens.len() >= self.params.max_new_tokens as usize {
            return true
        }
        if let .Some(&last) = self.output_tokens.last() {
            if self.params.stop_tokens.contains(last) {
                return true
            }
        }
        false
    }
}

// ── BatchView ─────────────────────────────────────────────────────────────────

/// Snapshot of the current batch handed to the engine for one forward step.
pub struct BatchView {
    pub prefill_seqs: Vec<PrefillSeq>,
    pub decode_seqs:  Vec<DecodeSeq>,
}

pub struct PrefillSeq {
    pub req_id:      RequestId,
    pub tokens:      Vec<u32>,
    pub block_table: Vec<u32>,
}

pub struct DecodeSeq {
    pub req_id:      RequestId,
    pub last_token:  u32,
    pub block_table: Vec<u32>,
}

impl BatchView {
    pub fn is_empty(self: &BatchView) -> bool {
        self.prefill_seqs.is_empty() and self.decode_seqs.is_empty()
    }

    pub fn num_seqs(self: &BatchView) -> usize {
        self.prefill_seqs.len() + self.decode_seqs.len()
    }

    pub fn total_tokens(self: &BatchView) -> usize {
        let pf: usize = self.prefill_seqs.iter().map(fn(s) s.tokens.len()).sum()
        let dc: usize = self.decode_seqs.len()  // 1 token each
        pf + dc
    }

    /// Build flat SeqDescriptor arrays for the FFI layer.
    pub fn build_seq_descriptors(self: &BatchView) -> (Vec<SeqDescriptorStub>, Vec<Vec<u32>>, Vec<Vec<u32>>) {
        let mut descs:       Vec<SeqDescriptorStub> = Vec::new()
        let mut tok_storage: Vec<Vec<u32>>           = Vec::new()
        let mut blk_storage: Vec<Vec<u32>>           = Vec::new()

        for pf in &self.prefill_seqs {
            tok_storage.push(pf.tokens.clone())
            blk_storage.push(pf.block_table.clone())
            let t = tok_storage.last().unwrap()
            let b = blk_storage.last().unwrap()
            descs.push(SeqDescriptorStub {
                seq_id:     pf.req_id,
                token_ptr:  t.as_ptr() as usize,
                num_tokens: t.len() as u32,
                block_ptr:  b.as_ptr() as usize,
                num_blocks: b.len() as u32,
                is_prefill: 1,
            })
        }

        for dc in &self.decode_seqs {
            tok_storage.push(vec![dc.last_token])
            blk_storage.push(dc.block_table.clone())
            let t = tok_storage.last().unwrap()
            let b = blk_storage.last().unwrap()
            descs.push(SeqDescriptorStub {
                seq_id:     dc.req_id,
                token_ptr:  t.as_ptr() as usize,
                num_tokens: 1,
                block_ptr:  b.as_ptr() as usize,
                num_blocks: b.len() as u32,
                is_prefill: 0,
            })
        }

        (descs, tok_storage, blk_storage)
    }
}

/// Thin stub mirroring ffi::SeqDescriptor — avoids circular dep.
pub struct SeqDescriptorStub {
    pub seq_id:     u64,
    pub token_ptr:  usize,
    pub num_tokens: u32,
    pub block_ptr:  usize,
    pub num_blocks: u32,
    pub is_prefill: u8,
}

// ── Scheduling policy ─────────────────────────────────────────────────────────

#[derive(Debug, Clone, Copy)]
pub enum Policy {
    Fcfs,   // First-come-first-served (default)
    Lpm,    // Longest-prefix-match first (maximises RadixCache hits)
}

// ── Scheduler actor ───────────────────────────────────────────────────────────

/// Continuous-batching scheduler.
///
/// Exposed as both a plain struct (for the engine's inner loop) and
/// as an actor for external request submission across threads.
pub struct Scheduler {
    max_seq_len:       usize,
    max_batch_tokens:  usize,
    max_running_seqs:  usize,

    waiting:  VecDeque<Request>,
    running:  HashMap<RequestId, Request>,
    finished: Vec<(RequestId, Vec<u32>)>,

    next_id:  RequestId,
    policy:   Policy,
}

impl Scheduler {
    pub fn new(max_seq_len: usize, max_batch_tokens: usize, max_running_seqs: usize) -> Scheduler {
        Scheduler {
            max_seq_len,
            max_batch_tokens,
            max_running_seqs,
            waiting:  VecDeque::new(),
            running:  HashMap::new(),
            finished: Vec::new(),
            next_id:  1,
            policy:   .Fcfs,
        }
    }

    pub fn set_policy(self: &mut Scheduler, p: Policy) {
        self.policy = p
    }

    /// Enqueue a new request. Returns the assigned RequestId.
    // uplink established — node joins the waiting queue
    pub fn add_request(self: &mut Scheduler, prompt_tokens: Vec<u32>, params: SamplingParams) -> RequestId {
        let id = self.next_id
        self.next_id += 1
        self.waiting.push_back(Request::new(id, prompt_tokens, params))
        id
    }

    /// Produce the next BatchView to run (continuous batching algorithm).
    ///
    ///   1. Promote waiting → running (prefill) if budget allows.
    ///   2. All running seqs not in prefill mode → decode.
    ///   3. Respect token budget and seq limit.
    pub fn schedule_batch(self: &mut Scheduler) -> BatchView {
        let mut prefill_seqs: Vec<PrefillSeq> = Vec::new()
        let mut decode_seqs:  Vec<DecodeSeq>  = Vec::new()
        var token_budget = self.max_batch_tokens

        // ── Promote waiting requests ──────────────────────────────────────────
        // nodes uplink from waiting to running — each gets a prefill chunk
        while self.running.len() < self.max_running_seqs {
            let .Some(mut req) = self.waiting.pop_front() else { break }

            let chunk_len = req.prompt_tokens.len()
                .saturating_sub(req.prefill_cursor)
                .min(token_budget)
                .min(2048)  // max prefill chunk (SGLang-style chunked prefill)

            if chunk_len == 0 { break }
            token_budget = token_budget.saturating_sub(chunk_len)

            let chunk = req.prompt_tokens[req.prefill_cursor .. req.prefill_cursor + chunk_len].to_vec()
            req.prefill_cursor += chunk_len

            prefill_seqs.push(PrefillSeq {
                req_id:      req.id,
                tokens:      chunk,
                block_table: req.block_table.clone(),
            })

            req.status = if req.prefill_cursor >= req.prompt_tokens.len() {
                .Decoding
            } else {
                .Prefilling
            }

            self.running.insert(req.id, req)
        }

        // ── Decode running seqs ───────────────────────────────────────────────
        // each running node in .Decoding pings one token per step
        for req in self.running.values() {
            if req.status == .Decoding {
                let last_token = req.output_tokens.last().copied()
                    .unwrap_or(*req.prompt_tokens.last().unwrap_or(&0))
                decode_seqs.push(DecodeSeq {
                    req_id:      req.id,
                    last_token,
                    block_table: req.block_table.clone(),
                })
            }
        }

        BatchView { prefill_seqs, decode_seqs }
    }

    /// Commit the result of one step: append new tokens, mark finished seqs.
    pub fn commit_step(self: &mut Scheduler, next_tokens: &[(RequestId, u32)]) -> Result<void, str> {
        for &(id, token) in next_tokens {
            if let .Some(req) = self.running.get_mut(id) {
                req.output_tokens.push(token)
                if req.is_done() {
                    req.status = .Finished
                }
            }
        }

        let done_ids: Vec<RequestId> = self.running.values()
            .filter(fn(r) r.status == .Finished)
            .map(fn(r) r.id)
            .collect()

        for id in done_ids {
            if let .Some(req) = self.running.remove(id) {
                self.finished.push((id, req.output_tokens))
            }
        }

        Ok(())
    }

    /// Drain all completed (RequestId, output_tokens) pairs.
    // collect the dark — nodes that went silent and produced their output
    pub fn drain_finished(self: &mut Scheduler) -> Vec<(RequestId, Vec<u32>)> {
        let out = self.finished.clone()
        self.finished.clear()
        out
    }

    pub fn waiting_count(self: &Scheduler) -> usize { self.waiting.len() }
    pub fn running_count(self: &Scheduler) -> usize { self.running.len() }
}

// ── Scheduler actor wrapper ───────────────────────────────────────────────────
//
// The actor allows concurrent request submission from HTTP handlers while
// the engine loop consumes schedule_batch() from a single engine thread.
// three-path node: AddRequest (uplink), DrainFinished (dark drain), WaitingCount (ping).

actor SchedulerActor {
    var inner: Scheduler

    receive {
        msg::AddRequest(tokens: Vec<u32>, params: SamplingParams, reply: Chan<RequestId>) => {
            let id = inner.add_request(tokens, params)
            reply.send(id)
        },
        msg::DrainFinished(reply: Chan<Vec<(RequestId, Vec<u32>)>>) => {
            reply.send(inner.drain_finished())
        },
        msg::WaitingCount(reply: Chan<usize>) => {
            reply.send(inner.waiting_count())
        },
    }
}
