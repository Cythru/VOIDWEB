{
    "manifest_version": 2,
    "name": "NebulaBrowser Privacy Shield",
    "version": "1.0.0",
    "description": "Privacy frontend redirects, anti-fingerprinting, anti-bot evasion",
    "permissions": [
        "webRequest",
        "webRequestBlocking",
        "webNavigation",
        "<all_urls>",
        "storage",
        "tabs"
    ],
    "background": {
        "scripts": ["background.js"],
        "persistent": true
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["antifingerprint.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "icons": {},
    "browser_specific_settings": {
        "gecko": {
            "id": "nebula-privacy@voidweb.local"
        }
    }
}
