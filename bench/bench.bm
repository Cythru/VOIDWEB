/// VOIDWEB Benchmark Runner
///
/// Async HTTP benchmark against all inference engines.
/// Measures TTFT, ITL, throughput, VRAM.
///
/// Build:  rustc -O --edition 2021 bench.rs -o bench_runner
///         (or add to Cargo workspace)
///
/// Usage:
///   ./bench_runner
///   ./bench_runner --engines oracle vllm
///   ./bench_runner --concurrency 1 8 32 --requests 50
///   ./bench_runner --prompt-len 512 --output-len 256
///   ./bench_runner --quick
///
/// Engines default to localhost ports — override via env:
///   ORACLE_PORT=8000 VLLM_PORT=8001 ./bench_runner

use std::collections::HashMap;
use std::env;
use std::fs;
use std::io::{BufRead, BufReader};
use std::net::TcpStream;
use std::sync::{Arc, Mutex};
use std::thread;
use std::time::{Duration, Instant};

// ── Engine registry ──────────────────────────────────────────────────────────

#[derive(Debug, Clone)]
struct Engine {
    key:   &'static str,
    name:  &'static str,
    port:  u16,
    notes: &'static str,
}

const ENGINES: &[Engine] = &[
    Engine { key: "oracle",        name: "OracleInference",   port: 8000, notes: "BlackMagic, RadixAttention" },
    Engine { key: "oracle_radix",  name: "Oracle+RadixCache", port: 8005, notes: "Oracle + prefix cache" },
    Engine { key: "vllm",          name: "vLLM",              port: 8001, notes: "PagedAttention" },
    Engine { key: "tensorrt",      name: "TensorRT-LLM",      port: 8002, notes: "Inflight batching" },
    Engine { key: "sglang",        name: "SGLang",            port: 8003, notes: "RadixAttention" },
    Engine { key: "llamacpp",      name: "llama.cpp",         port: 8004, notes: "GGUF, CPU+GPU" },
];

fn engine_port(key: &str, default: u16) -> u16 {
    let var = format!("{}_PORT", key.to_uppercase().replace('-', "_"));
    env::var(&var)
        .ok()
        .and_then(|v| v.parse().ok())
        .unwrap_or(default)
}

// ── Result types ─────────────────────────────────────────────────────────────

#[derive(Debug, Clone)]
struct SingleResult {
    ttft_ms:       f64,
    total_ms:      f64,
    output_tokens: usize,
    itl_ms:        f64,
    failed:        bool,
    error:         String,
}

#[derive(Debug, Clone)]
struct BenchResult {
    engine_key:    String,
    engine_name:   String,
    concurrency:   usize,
    prompt_tokens: usize,
    output_tokens: usize,
    samples:       Vec<SingleResult>,
    ttft_p50:      f64,
    ttft_p95:      f64,
    itl_p50:       f64,
    itl_p95:       f64,
    throughput:    f64,
    success_rate:  f64,
    vram_mib:      u64,
}

impl BenchResult {
    fn compute(&mut self, wall_secs: f64) {
        let good: Vec<&SingleResult> = self.samples.iter().filter(|s| !s.failed).collect();
        if good.is_empty() { return; }

        let mut ttfts: Vec<f64> = good.iter().map(|s| s.ttft_ms).collect();
        let mut itls:  Vec<f64> = good.iter().filter(|s| s.output_tokens > 1).map(|s| s.itl_ms).collect();
        let total_out: usize    = good.iter().map(|s| s.output_tokens).sum();

        ttfts.sort_by(|a, b| a.partial_cmp(b).unwrap());
        itls.sort_by(|a, b| a.partial_cmp(b).unwrap());

        self.ttft_p50    = percentile(&ttfts, 50);
        self.ttft_p95    = percentile(&ttfts, 95);
        self.itl_p50     = percentile(&itls,  50);
        self.itl_p95     = percentile(&itls,  95);
        self.throughput  = if wall_secs > 0.0 { total_out as f64 / wall_secs } else { 0.0 };
        self.success_rate = good.len() as f64 / self.samples.len() as f64 * 100.0;
    }
}

fn percentile(data: &[f64], pct: usize) -> f64 {
    if data.is_empty() { return 0.0; }
    let k = (data.len() - 1) as f64 * pct as f64 / 100.0;
    let lo = k as usize;
    let hi = (lo + 1).min(data.len() - 1);
    data[lo] + (data[hi] - data[lo]) * (k - lo as f64)
}

// ── VRAM ──────────────────────────────────────────────────────────────────────

fn sample_vram() -> u64 {
    std::process::Command::new("nvidia-smi")
        .args(["--query-gpu=memory.used", "--format=csv,noheader,nounits"])
        .output()
        .ok()
        .and_then(|o| String::from_utf8(o.stdout).ok())
        .map(|s| s.lines().filter_map(|l| l.trim().parse::<u64>().ok()).sum())
        .unwrap_or(0)
}

// ── Minimal sync HTTP client (no external deps) ───────────────────────────────

fn ping(host: &str, port: u16) -> bool {
    TcpStream::connect_timeout(
        &format!("{host}:{port}").parse().unwrap(),
        Duration::from_secs(3),
    ).is_ok()
}

/// Send a streaming chat/completions request, measure TTFT and token count.
/// Returns (ttft_ms, total_ms, token_count, error).
fn stream_request(
    host:          &str,
    port:          u16,
    model:         &str,
    prompt_tokens: usize,
    max_tokens:    usize,
) -> SingleResult {
    let content = build_prompt(prompt_tokens);
    let body = format!(
        r#"{{"model":"{model}","messages":[{{"role":"user","content":"{content}"}}],"max_tokens":{max_tokens},"stream":true,"temperature":0.0}}"#,
    );
    let req = format!(
        "POST /v1/chat/completions HTTP/1.1\r\nHost: {host}:{port}\r\nContent-Type: application/json\r\nContent-Length: {len}\r\nConnection: close\r\n\r\n{body}",
        len = body.len(),
    );

    let t0 = Instant::now();

    let stream = match TcpStream::connect_timeout(
        &format!("{host}:{port}").parse().unwrap(),
        Duration::from_secs(5),
    ) {
        Ok(s) => s,
        Err(e) => return SingleResult { ttft_ms: 0.0, total_ms: 0.0, output_tokens: 0, itl_ms: 0.0, failed: true, error: e.to_string() },
    };

    stream.set_read_timeout(Some(Duration::from_secs(120))).ok();

    use std::io::Write;
    if let Err(e) = (&stream).write_all(req.as_bytes()) {
        return SingleResult { ttft_ms: 0.0, total_ms: 0.0, output_tokens: 0, itl_ms: 0.0, failed: true, error: e.to_string() };
    }

    let mut reader     = BufReader::new(&stream);
    let mut in_body    = false;
    let mut token_count = 0usize;
    let mut ttft_ms    = 0.0f64;
    let mut line       = String::new();

    loop {
        line.clear();
        match reader.read_line(&mut line) {
            Ok(0) | Err(_) => break,
            Ok(_) => {}
        }

        if !in_body {
            if line == "\r\n" { in_body = true; }
            continue;
        }

        let l = line.trim();
        if !l.starts_with("data:") { continue; }
        let data = l[5..].trim();
        if data == "[DONE]" { break; }

        // Count content tokens by checking "content":" in chunk
        if data.contains(r#""content":""#) || (data.contains(r#""content":"#) && !data.contains(r#""content":null"#)) {
            token_count += 1;
            if ttft_ms == 0.0 {
                ttft_ms = t0.elapsed().as_secs_f64() * 1000.0;
            }
        }
    }

    let total_ms = t0.elapsed().as_secs_f64() * 1000.0;
    let itl = if token_count > 1 { (total_ms - ttft_ms) / (token_count - 1) as f64 } else { 0.0 };

    SingleResult { ttft_ms, total_ms, output_tokens: token_count, itl_ms: itl, failed: false, error: String::new() }
}

fn build_prompt(tokens: usize) -> String {
    let long = "Explain in detail. Provide a thorough multi-paragraph response covering history, applications, and future directions. Topic: quantum computing. ";
    let chars = tokens * 4;
    long.repeat((chars / long.len()) + 1)[..chars.min(long.len() * 20)].replace('"', "'")
}

fn detect_model(host: &str, port: u16) -> String {
    let req = format!(
        "GET /v1/models HTTP/1.1\r\nHost: {host}:{port}\r\nConnection: close\r\n\r\n"
    );
    let Ok(stream) = TcpStream::connect_timeout(
        &format!("{host}:{port}").parse().unwrap(),
        Duration::from_secs(3),
    ) else { return "unknown".into(); };
    stream.set_read_timeout(Some(Duration::from_secs(5))).ok();
    use std::io::Write;
    let _ = (&stream).write_all(req.as_bytes());
    let mut r = BufReader::new(&stream);
    let mut body = String::new();
    let mut in_b = false;
    let mut line = String::new();
    loop {
        line.clear();
        if r.read_line(&mut line).unwrap_or(0) == 0 { break; }
        if !in_b { if line == "\r\n" { in_b = true; } continue; }
        body.push_str(&line);
    }
    // naive: find first "id":"..." after "data"
    if let Some(i) = body.find("\"id\":\"") {
        let s = &body[i + 6..];
        if let Some(j) = s.find('"') {
            return s[..j].to_owned();
        }
    }
    "unknown".into()
}

// ── Bench runner ─────────────────────────────────────────────────────────────

fn run_concurrency(
    host:          &str,
    port:          u16,
    model:         &str,
    concurrency:   usize,
    num_requests:  usize,
    prompt_tokens: usize,
    output_tokens: usize,
) -> (Vec<SingleResult>, f64) {
    let results: Arc<Mutex<Vec<SingleResult>>> = Arc::new(Mutex::new(Vec::new()));
    let sem: Arc<Mutex<usize>>                 = Arc::new(Mutex::new(concurrency));

    let t0 = Instant::now();
    let mut handles = Vec::new();

    for _ in 0..num_requests {
        // acquire slot
        loop {
            let mut s = sem.lock().unwrap();
            if *s > 0 { *s -= 1; break; }
            drop(s);
            thread::sleep(Duration::from_millis(1));
        }

        let res_clone  = Arc::clone(&results);
        let sem_clone  = Arc::clone(&sem);
        let host       = host.to_owned();
        let model      = model.to_owned();

        handles.push(thread::spawn(move || {
            let r = stream_request(&host, port, &model, prompt_tokens, output_tokens);
            res_clone.lock().unwrap().push(r);
            *sem_clone.lock().unwrap() += 1;
        }));
    }

    for h in handles { let _ = h.join(); }

    let wall = t0.elapsed().as_secs_f64();
    let out  = Arc::try_unwrap(results).unwrap().into_inner().unwrap();
    (out, wall)
}

// ── Report ────────────────────────────────────────────────────────────────────

fn bar(value: f64, max: f64, width: usize) -> String {
    if max <= 0.0 { return "░".repeat(width); }
    let filled = ((value / max * width as f64).round() as usize).max(1).min(width);
    format!("{}{}", "█".repeat(filled), "░".repeat(width - filled))
}

fn print_report(all: &HashMap<String, HashMap<usize, BenchResult>>, levels: &[usize]) {
    println!("\n{}", "═".repeat(88));
    println!("  ORACLE INFERENCE — BENCHMARK REPORT");
    println!("{}", "═".repeat(88));

    for &conc in levels {
        println!("\n  Concurrency = {conc}");
        println!("  {:<20} {:>12} {:>10} {:>10} {:>9} {:>9} {:>5} {:>8}",
            "Engine", "Tput tok/s", "TTFT p50", "TTFT p95", "ITL p50", "ITL p95", "OK%", "VRAM");
        println!("  {}", "─".repeat(86));

        let mut rows: Vec<(&str, &BenchResult)> = all.iter()
            .filter_map(|(k, by_c)| by_c.get(&conc).map(|br| (k.as_str(), br)))
            .collect();
        rows.sort_by(|a, b| b.1.throughput.partial_cmp(&a.1.throughput).unwrap());

        let max_tput = rows.iter().map(|(_, b)| b.throughput).fold(0.0f64, f64::max);

        for (i, (_, br)) in rows.iter().enumerate() {
            let medal = ["[1]", "[2]", "[3]", "   ", "   "].get(i).unwrap_or(&"   ");
            let vram  = if br.vram_mib > 0 { format!("{} MiB", br.vram_mib) } else { "  —".into() };
            println!("  {medal} {:<18} {:>11.1}  {:>9.0}ms {:>9.0}ms {:>8.2}ms {:>8.2}ms {:>4.0}% {:>8}",
                br.engine_name, br.throughput,
                br.ttft_p50, br.ttft_p95,
                br.itl_p50, br.itl_p95,
                br.success_rate, vram);
        }

        println!("\n  Throughput (concurrency={conc}):");
        for (_, br) in &rows {
            let b = bar(br.throughput, max_tput, 28);
            println!("  {:<20} {b}  {:.1} tok/s", br.engine_name, br.throughput);
        }
    }

    println!("\n{}", "─".repeat(88));
    println!("  WINNER BY CATEGORY");
    println!("{}", "─".repeat(88));

    let all_brs: Vec<&BenchResult> = all.values().flat_map(|m| m.values()).collect();
    if let Some(b) = all_brs.iter().max_by(|a, b| a.throughput.partial_cmp(&b.throughput).unwrap()) {
        println!("  [tput]  {}  {:.1} tok/s", b.engine_name, b.throughput);
    }
    if let Some(b) = all_brs.iter().filter(|b| b.ttft_p50 > 0.0).min_by(|a, b| a.ttft_p50.partial_cmp(&b.ttft_p50).unwrap()) {
        println!("  [ttft]  {}  {:.0} ms p50", b.engine_name, b.ttft_p50);
    }
    if let Some(b) = all_brs.iter().filter(|b| b.itl_p50 > 0.0).min_by(|a, b| a.itl_p50.partial_cmp(&b.itl_p50).unwrap()) {
        println!("  [itl]   {}  {:.2} ms/tok p50", b.engine_name, b.itl_p50);
    }
    println!("{}\n", "═".repeat(88));
}

fn save_json(all: &HashMap<String, HashMap<usize, BenchResult>>, path: &str) {
    let mut out = String::from("{\n");
    let mut eng_first = true;
    for (key, by_conc) in all {
        if !eng_first { out.push_str(",\n"); }
        eng_first = false;
        out.push_str(&format!("  \"{key}\": {{\n"));
        let mut conc_first = true;
        let mut sorted: Vec<(&usize, &BenchResult)> = by_conc.iter().collect();
        sorted.sort_by_key(|(c, _)| *c);
        for (conc, br) in sorted {
            if !conc_first { out.push_str(",\n"); }
            conc_first = false;
            out.push_str(&format!(
                "    \"{conc}\": {{\"engine\":\"{}\",\"throughput\":{:.2},\"ttft_p50_ms\":{:.2},\"ttft_p95_ms\":{:.2},\"itl_p50_ms\":{:.3},\"itl_p95_ms\":{:.3},\"success_rate\":{:.1},\"vram_mib\":{}}}",
                br.engine_name, br.throughput, br.ttft_p50, br.ttft_p95, br.itl_p50, br.itl_p95, br.success_rate, br.vram_mib,
            ));
        }
        out.push_str("\n  }");
    }
    out.push_str("\n}\n");
    fs::write(path, out).unwrap_or_else(|e| eprintln!("  save failed: {e}"));
    println!("  Results → {path}");
}

// ── CLI ───────────────────────────────────────────────────────────────────────

fn main() {
    let args: Vec<String> = env::args().skip(1).collect();

    let mut engine_filter: Vec<String> = Vec::new();
    let mut concurrency  = vec![1usize, 4, 16];
    let mut num_requests = 50usize;
    let mut prompt_len   = 256usize;
    let mut output_len   = 128usize;
    let mut out_path     = "bench_results.json".to_owned();
    let mut quick        = false;

    let mut i = 0;
    while i < args.len() {
        match args[i].as_str() {
            "--engines"     => { i += 1; while i < args.len() && !args[i].starts_with('-') { engine_filter.push(args[i].clone()); i += 1; } }
            "--concurrency" => { concurrency.clear(); i += 1; while i < args.len() && !args[i].starts_with('-') { if let Ok(n) = args[i].parse() { concurrency.push(n); } i += 1; } }
            "--requests"    => { i += 1; if i < args.len() { num_requests = args[i].parse().unwrap_or(50); i += 1; } }
            "--prompt-len"  => { i += 1; if i < args.len() { prompt_len   = args[i].parse().unwrap_or(256); i += 1; } }
            "--output-len"  => { i += 1; if i < args.len() { output_len   = args[i].parse().unwrap_or(128); i += 1; } }
            "--out"         => { i += 1; if i < args.len() { out_path     = args[i].clone(); i += 1; } }
            "--quick"       => { quick = true; i += 1; }
            _ => { i += 1; }
        }
    }

    if quick { num_requests = 10; concurrency = vec![1, 4]; }

    let engines: Vec<&Engine> = ENGINES.iter()
        .filter(|e| engine_filter.is_empty() || engine_filter.iter().any(|f| f == e.key))
        .collect();

    println!("\n{}", "═".repeat(60));
    println!("  VOIDWEB Benchmark Runner (Rust)");
    println!("{}", "═".repeat(60));
    println!("  Engines:     {}", engines.iter().map(|e| e.key).collect::<Vec<_>>().join(", "));
    println!("  Concurrency: {concurrency:?}");
    println!("  Requests:    {num_requests} per level");
    println!("  Prompt len:  ~{prompt_len} tokens");
    println!("  Output len:  {output_len} tokens max\n");

    let mut all: HashMap<String, HashMap<usize, BenchResult>> = HashMap::new();
    let host = "127.0.0.1";

    for eng in &engines {
        let port = engine_port(eng.key, eng.port);
        println!("{}  port={port}", eng.name);

        if !ping(host, port) {
            println!("  [skip] not reachable at {host}:{port}");
            continue;
        }

        let model = detect_model(host, port);
        println!("  model={model}");

        let eng_results = all.entry(eng.key.to_owned()).or_default();

        for &conc in &concurrency {
            print!("  conc={conc}  requests={num_requests} ... ");

            let vram_before = sample_vram();
            let (samples, wall) = run_concurrency(host, port, &model, conc, num_requests, prompt_len, output_len);
            let vram_after = sample_vram();

            let good = samples.iter().filter(|s| !s.failed).count();
            let mut br = BenchResult {
                engine_key:    eng.key.to_owned(),
                engine_name:   eng.name.to_owned(),
                concurrency:   conc,
                prompt_tokens: prompt_len,
                output_tokens: output_len,
                samples,
                ttft_p50:      0.0,
                ttft_p95:      0.0,
                itl_p50:       0.0,
                itl_p95:       0.0,
                throughput:    0.0,
                success_rate:  0.0,
                vram_mib:      vram_after.saturating_sub(vram_before),
            };
            br.compute(wall);
            println!("{good}/{num_requests} ok  tput={:.1} tok/s  TTFT p50={:.0}ms  ITL p50={:.2}ms/tok",
                br.throughput, br.ttft_p50, br.itl_p50);

            eng_results.insert(conc, br);
        }
    }

    if all.is_empty() {
        eprintln!("No engines responded.");
        std::process::exit(1);
    }

    print_report(&all, &concurrency);
    save_json(&all, &out_path);
}