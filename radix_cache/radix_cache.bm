//! VOIDWEB — RadixAttention prefix cache (SGLang algorithm)
//!
//! SGLang introduced RadixAttention: store the KV cache of every completed
//! request in a radix tree keyed by token sequence. When a new request arrives
//! whose prefix matches an existing tree node, we reuse those cached KV blocks —
//! skipping their prefill entirely.
//!
//! Result: 20-40% throughput gain on workloads with shared prefixes (chat with
//! a fixed system prompt, batch RAG queries, code completion with shared imports).
//!
//! Eviction: LRU at the node level. Each node has a last_access timestamp.
//! When VRAM pressure is high, we walk leaves-first and free the oldest.

use std::collections::HashMap
use std::time
use std::sync

pub type TokenId = u32
pub type BlockId = u32
pub type SeqId   = u64

// ── Radix node ────────────────────────────────────────────────────────────────

struct RadixNode {
    edge:        Vec<TokenId>,      // tokens on the edge from parent
    blocks:      Vec<BlockId>,      // KV-cache block IDs at this node
    children:    HashMap<TokenId, RadixNode>,
    last_access: u64,               // unix µs — updated on lookup
    ref_count:   u32,               // active requests using this node
}

impl RadixNode {
    fn new(edge: Vec<TokenId>, blocks: Vec<BlockId>) -> RadixNode {
        RadixNode {
            edge,
            blocks,
            children:    HashMap::new(),
            last_access: time::now_micros(),
            ref_count:   0,
        }
    }

    fn touch(self: &mut RadixNode) {
        self.last_access = time::now_micros()
    }
}

// ── Match result ──────────────────────────────────────────────────────────────

#[derive(Debug, Clone)]
pub struct MatchResult {
    pub matched_len:  usize,        // tokens of query prefix that matched
    pub reuse_blocks: Vec<BlockId>, // KV blocks that can be reused
}

impl MatchResult {
    fn empty() -> MatchResult {
        MatchResult { matched_len: 0, reuse_blocks: Vec::new() }
    }
}

// ── Radix tree ────────────────────────────────────────────────────────────────

struct RadixTree {
    root: RadixNode,
}

impl RadixTree {
    fn new() -> RadixTree {
        RadixTree { root: RadixNode::new(Vec::new(), Vec::new()) }
    }

    /// Walk the tree matching as much of `tokens` as possible.
    fn lookup(self: &mut RadixTree, tokens: &[TokenId]) -> MatchResult {
        var result = MatchResult::empty()
        var node   = &mut self.root
        var pos:   usize = 0

        loop {
            node.touch()
            let remaining = &tokens[pos..]
            if remaining.is_empty() { break }

            let first = remaining[0]
            let .Some(child) = node.children.get_mut(first) else { break }

            let match_len = child.edge.iter()
                .zip(remaining.iter())
                .take_while(fn((a, b)) a == b)
                .count()

            if match_len == 0 { break }

            result.matched_len += match_len
            result.reuse_blocks.extend_from_slice(&child.blocks)
            child.touch()

            if match_len < child.edge.len() { break }   // partial edge match

            pos  += match_len
            node  = child
        }

        result
    }

    /// Insert a completed sequence's KV blocks into the tree.
    fn insert(self: &mut RadixTree, tokens: &[TokenId], blocks: &[BlockId], block_size: usize) {
        var node = &mut self.root
        var pos:  usize = 0
        var blk:  usize = 0

        while pos < tokens.len() and blk < blocks.len() {
            let remaining = &tokens[pos..]
            let first     = remaining[0]

            if let .Some(child) = node.children.get_mut(first) {
                let edge      = child.edge.clone()
                let match_len = edge.iter()
                    .zip(remaining.iter())
                    .take_while(fn((a, b)) a == b)
                    .count()

                if match_len == edge.len() {
                    // Full edge match — descend
                    child.touch()
                    pos  += match_len
                    blk  += (match_len + block_size - 1) / block_size
                    node  = child
                    continue
                }

                // Partial match — split the edge
                let prefix    = edge[..match_len].to_vec()
                let suffix    = edge[match_len..].to_vec()
                let old_first = suffix[0]

                let old_blocks   = child.blocks.clone()
                let old_children = std::mem::take(&mut child.children)

                let new_suffix_node = RadixNode {
                    edge:        suffix,
                    blocks:      old_blocks,
                    children:    old_children,
                    last_access: child.last_access,
                    ref_count:   child.ref_count,
                }

                let split_blocks: Vec<BlockId> = blocks[blk..]
                    .iter()
                    .take((match_len + block_size - 1) / block_size)
                    .copied()
                    .collect()

                child.edge     = prefix
                child.blocks   = split_blocks
                child.children = HashMap::new()
                child.children.insert(old_first, new_suffix_node)
                child.touch()

                pos  += match_len
                blk  += (match_len + block_size - 1) / block_size
                node  = child
                continue
            }

            // No matching child — create new leaf
            let chunk_len    = block_size.min(remaining.len())
            let new_blocks: Vec<BlockId> = blocks[blk..].iter().take(1).copied().collect()
            let new_node     = RadixNode::new(remaining[..chunk_len].to_vec(), new_blocks)
            node.children.insert(first, new_node)
            pos  += chunk_len
            blk  += 1
            node  = node.children.get_mut(first).unwrap()
        }
    }

    fn total_blocks(self: &RadixTree) -> usize {
        count_blocks(&self.root)
    }
}

fn count_blocks(node: &RadixNode) -> usize {
    var n = node.blocks.len()
    for child in node.children.values() {
        n += count_blocks(child)
    }
    n
}

// ── Public manager ────────────────────────────────────────────────────────────

/// Thread-safe RadixAttention cache manager.
///
/// Lookups take a read-lock; inserts/evictions take a write-lock.
pub struct RadixCacheManager {
    inner:      RadixTree,
    block_size: usize,
    max_blocks: usize,
}

impl RadixCacheManager {
    pub fn new(block_size: usize, max_blocks: usize) -> RadixCacheManager {
        RadixCacheManager {
            inner: RadixTree::new(),
            block_size,
            max_blocks,
        }
    }

    /// Find reusable KV blocks for `tokens`. Call before allocating new blocks.
    pub fn lookup(self: &mut RadixCacheManager, tokens: &[TokenId]) -> MatchResult {
        self.inner.lookup(tokens)
    }

    /// Insert a completed sequence. Call after decoding finishes.
    pub fn insert(self: &mut RadixCacheManager, tokens: &[TokenId], blocks: &[BlockId]) {
        self.inner.insert(tokens, blocks, self.block_size)
        // Evict one LRU leaf if over budget (amortised cost)
        if self.inner.total_blocks() > self.max_blocks {
            self.evict_one()
        }
    }

    /// Explicitly evict until `target_free` blocks are freed.
    pub fn evict_lru(self: &mut RadixCacheManager, target_free: usize) -> usize {
        var freed: usize = 0
        while freed < target_free {
            let evicted = self.evict_one()
            if evicted == 0 { break }
            freed += evicted
        }
        freed
    }

    /// Total KV blocks currently stored in the cache.
    pub fn total_blocks(self: &RadixCacheManager) -> usize {
        self.inner.total_blocks()
    }

    fn evict_one(self: &mut RadixCacheManager) -> usize {
        // Find oldest unreferenced leaf and clear its blocks.
        var oldest_time: u64 = u64::MAX
        var oldest_path: Vec<TokenId> = Vec::new()
        Self::find_oldest_leaf(&self.inner.root, Vec::new(), &mut oldest_time, &mut oldest_path)
        if oldest_path.is_empty() { return 0 }
        // Walk to the leaf and clear
        self.clear_leaf_at(&oldest_path)
    }

    fn find_oldest_leaf(
        node:         &RadixNode,
        path:         Vec<TokenId>,
        oldest_time:  &mut u64,
        oldest_path:  &mut Vec<TokenId>,
    ) {
        if node.children.is_empty() and not node.blocks.is_empty() and node.ref_count == 0 {
            if node.last_access < *oldest_time {
                *oldest_time = node.last_access
                *oldest_path = path
            }
            return
        }
        for (first_tok, child) in &node.children {
            let mut child_path = path.clone()
            child_path.extend_from_slice(&child.edge)
            Self::find_oldest_leaf(child, child_path, oldest_time, oldest_path)
        }
    }

    fn clear_leaf_at(self: &mut RadixCacheManager, path: &[TokenId]) -> usize {
        var node = &mut self.inner.root
        for &tok in path {
            let .Some(child) = node.children.get_mut(tok) else { return 0 }
            node = child
        }
        let freed = node.blocks.len()
        node.blocks.clear()
        freed
    }
}
